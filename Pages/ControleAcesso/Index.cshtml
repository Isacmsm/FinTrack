@page
@using Microsoft.AspNetCore.Http
@using FinTrack.Data
@inject DaoService Dao
@functions {

    public class LoginRequest
    {
        public string Email { get; set; }
        public string Senha { get; set; }
    }

    public class UsuarioLogado
    {
        public int Id { get; set; }
        public string Nome { get; set; }
        public string Email { get; set; }
    }

    string email;
    string senha;

    private void AlimentarVariaveis(LoginRequest request)
    {
        email = request.Email;
        senha = request.Senha;
    }

    private UsuarioLogado AbreSessao()
    {
        var parametros = new Dictionary<string, object>
        {
            { "@Email", email },
            { "@Senha", senha }
        };

        return Dao.ExecutarProcedureList<UsuarioLogado>("FT_Usuario_Login", parametros).FirstOrDefault();
    }

    private void SalvarSessao(UsuarioLogado usuario)
    {
        HttpContext.Session.SetInt32("IdUser", usuario.Id);
        HttpContext.Session.SetString("NomeUser", usuario.Nome);
        HttpContext.Session.SetString("EmailUser", usuario.Email);
    }

    public void OnGet()
    {
    }

    public IActionResult OnPostLogin([FromBody] LoginRequest request)
    {
        AlimentarVariaveis(request);

        return Util.ExecutarHandler(() =>
        {
            var usuario = AbreSessao();

            if (usuario != null)
            {
                SalvarSessao(usuario);
                return new JsonResult(new { sucesso = true }) { StatusCode = 200 };
            }

            return new JsonResult(new { mensagem = "Erro inesperado no login" }) { StatusCode = 400 };
        });
    }
}
@{
    ViewData["Title"] = "Login";
}

        <!-- Card de Login (esquerda) -->
        <div class="w-full md:w-[480px] min-h-screen flex items-center justify-center p-8 md:p-12 z-10">
            <div class="card-glass rounded-3xl shadow-2xl p-10 w-full max-w-md fade-in">

                <!-- Logo -->
                <div class="text-center mb-8 fade-in fade-in-delay-1">
                    <img src="~/images/carteira.png" alt="FinTrack" class="w-16 h-16 mx-auto mb-3" />
                    <h1 class="font-display text-3xl font-bold text-gray-900">FinTrack</h1>
                    <p class="text-gray-400 text-sm mt-1">Suas finanças no controle</p>
                </div>

                <!-- Mensagem de boas-vindas -->
                <div class="mb-8 fade-in fade-in-delay-2">
                    <h2 class="font-display text-xl font-semibold text-gray-800">Bem-vindo de volta</h2>
                    <p class="text-gray-400 text-sm mt-1">Entre na sua conta para continuar</p>
                </div>

                <!-- Formulário -->
                <div class="space-y-5 fade-in fade-in-delay-3" id="formLogin">

                    @Html.AntiForgeryToken()

                    <!-- E-mail -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">E-mail</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="seu@@email.com"
                            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-300 input-focus transition-all"
                        />
                        <span class="text-red-500 text-xs mt-1 hidden" id="erroEmail"></span>
                    </div>

                    <!-- Senha -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Senha</label>
                        <div class="relative">
                            <input
                                type="password"
                                id="senha"
                                name="senha"
                                placeholder="••••••••"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-300 input-focus transition-all pr-12"
                            />
                            <button
                                type="button"
                                onclick="toggleSenha()"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors"
                            >
                                <svg id="iconOlho" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                </svg>
                            </button>
                        </div>
                        <span class="text-red-500 text-xs mt-1 hidden" id="erroSenha"></span>
                    </div>

                    <!-- Erro geral -->
                    <div class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl px-4 py-3" id="erroGeral"></div>

                    <!-- Botão Login -->
                    <button
                        type="button"
                        onclick="fazerLogin()"
                        class="w-full btn-login text-white font-semibold py-3.5 rounded-xl text-base"
                        id="btnLogin"
                    >
                        Entrar
                    </button>

                    <!-- Divisor -->
                    <div class="divider text-gray-300 text-xs">ou</div>

                    <!-- Link Registro -->
                    <div class="text-center">
                        <p class="text-gray-500 text-sm">
                            Não tem uma conta?
                            <a asp-page="/ControleAcesso/Registro" class="text-emerald-600 font-semibold hover:text-emerald-700 transition-colors">
                                Criar conta
                            </a>
                        </p>
                    </div>
                </div>

            </div>
        </div>

@section Scripts {
    <script>
        function toggleSenha() {
            const input = document.getElementById('senha');
            const icon = document.getElementById('iconOlho');

            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = `
                    <path d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                `;
            } else {
                input.type = 'password';
                icon.innerHTML = `
                    <path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                `;
            }
        }

        function fazerLogin() {
            // Limpa erros anteriores
            limparErros();

            const email = $('#email').val();
            const senha = $('#senha').val();

            $('#btnLogin').prop('disabled', true).text('Entrando...');

            $.ajax({
                url: '/ControleAcesso?handler=Login',
                type: 'POST',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify({ email: email, senha: senha }),
                success: function (response) {
                    if (response.sucesso) {
                        window.location.href = '/Dashboard';
                    }
                },
                error: function (xhr) {
                    $('#btnLogin').prop('disabled', false).text('Entrar');

                    mostrarErros(xhr);
                }
            });
        }

        // Enter para fazer login
        $(document).on('keypress', '#email, #senha', function (e) {
            if (e.which === 13) {
                fazerLogin();
            }
        });
    </script>
}
